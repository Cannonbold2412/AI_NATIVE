# Copy this file to .env and fill values for local development.
SKILL_HOST=127.0.0.1
SKILL_PORT=8000
SKILL_DEFAULT_ACTION_TIMEOUT_MS=5000
SKILL_SCREENSHOT_JPEG_QUALITY=78

# LLM toggles
SKILL_LLM_ENABLED=true
SKILL_LLM_SEMANTIC_ENRICHMENT=true
SKILL_LLM_VISION_REASONING=true
SKILL_LLM_RECOVERY_ASSIST=true
SKILL_LLM_MAX_CALLS_PER_STEP=1
SKILL_LLM_TIMEOUT_MS=2000

# LLM provider (set for your provider)
SKILL_LLM_ENDPOINT=https://integrate.api.nvidia.com/v1
SKILL_LLM_API_KEY=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
SKILL_LLM_API_KEYS=
SKILL_LLM_TEXT_MODEL=meta/llama-3.1-70b-instruct
SKILL_LLM_VISION_MODEL=meta/llama-3.2-90b-vision-instruct
SKILL_LLM_DEBUG=false

# Copy this file to .env and fill values for local development.

# Generated bundle folder at repo root (default skill_package). After UI rename on /packages, `.skill_bundle_root` wins.
SKILL_PACKAGE_BUNDLE_ROOT=skill_package

SKILL_HOST=127.0.0.1
SKILL_PORT=8000
SKILL_DEFAULT_ACTION_TIMEOUT_MS=5000
SKILL_SCREENSHOT_JPEG_QUALITY=78

# LLM toggles and shared settings
SKILL_LLM_ENABLED=true
SKILL_LLM_SEMANTIC_ENRICHMENT=true
SKILL_LLM_VISION_REASONING=true
SKILL_LLM_RECOVERY_ASSIST=true
SKILL_LLM_MAX_CALLS_PER_STEP=1
SKILL_LLM_ANCHOR_VISION=true
SKILL_LLM_PARALLEL_FANOUT_ANCHOR_VISION=true
SKILL_LLM_DEBUG=false

# LLM 1: Skill Pack Structuring (compile time, structures raw recordings into skill JSON)
SKILL_LLM_PACK_ENDPOINT=
SKILL_LLM_PACK_API_KEY=
SKILL_LLM_PACK_MODEL=
SKILL_LLM_PACK_TIMEOUT_MS=600000
SKILL_LLM_PACK_MAX_ATTEMPTS=2

# LLM 2: Vision (anchor generation + visual recovery, multimodal)
SKILL_LLM_VISION_ENDPOINT=
SKILL_LLM_VISION_API_KEY=
SKILL_LLM_VISION_MODEL=
SKILL_LLM_VISION_TIMEOUT_MS=120000

# LLM 3: Runtime Text (semantic enrichment, intent generation, recovery assist)
SKILL_LLM_TEXT_ENDPOINT=
SKILL_LLM_TEXT_API_KEY=
SKILL_LLM_TEXT_MODEL=
SKILL_LLM_TEXT_TIMEOUT_MS=2000

# Production API boundary
SKILL_ENVIRONMENT=local
SKILL_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SKILL_CORS_PREVIEW_ORIGIN_REGEX=https://.*\.vercel\.app
SKILL_MAX_JSON_BODY_BYTES=1000000

# Clerk auth. Set SKILL_AUTH_REQUIRED=true outside local/dev.
# Issuer = Frontend API URL from Clerk (e.g. https://<instance>.clerk.accounts.dev).
# JWKS URL = same host + /.well-known/jwks.json
SKILL_AUTH_REQUIRED=false
SKILL_CLERK_ISSUER=
SKILL_CLERK_JWKS_URL=
SKILL_CLERK_AUTHORIZED_PARTIES=
SKILL_CLERK_AUDIENCE=

# Production backing services
SKILL_DATABASE_URL=
SKILL_REDIS_URL=
SKILL_BLOB_READ_WRITE_TOKEN=
SKILL_WORKER_QUEUE_NAME=ai-native-jobs
SKILL_WORKER_DEAD_LETTER_QUEUE_NAME=ai-native-jobs-dlq

# Stripe billing and app redirects
SKILL_STRIPE_SECRET_KEY=
SKILL_STRIPE_WEBHOOK_SECRET=
SKILL_STRIPE_PRICE_ID=
SKILL_APP_URL=http://localhost:5173

# GitHub OAuth App integration. Callback URL in GitHub:
# http://localhost:8000/api/v1/integrations/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/github/callback
GITHUB_OAUTH_FRONTEND_ORIGIN=http://localhost:3000

{
  "name": "conxa-build-studio",
  "version": "0.1.0",
  "description": "Conxa Build Studio — record, compile, and ship automation plugins",
  "main": "main.js",
  "author": "Conxa",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:electron": "cross-env CONXA_RENDERER_URL=http://localhost:5174 electron .",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:renderer && electron-builder --config electron-builder.yml",
    "test:bridge": "node test/bridge.test.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  }
}

[
  {
    "type": "navigate",
    "url": "https://dashboard.render.com/login"
  },
  {
    "type": "fill",
    "selector": "input[name=\"email\"]",
    "value": "{{user_email}}"
  },
  {
    "type": "fill",
    "selector": "input[name=\"password\"]",
    "value": "{{user_password}}"
  },
  {
    "type": "click",
    "selector": "text=Sign in"
  },
  {
    "type": "assert_visible",
    "selector": "text=New"
  },
  {
    "type": "scroll",
    "delta_y": 201.0
  },
  {
    "type": "click",
    "selector": "text={{db_name}}"
  },
  {
    "type": "scroll",
    "delta_y": -201.0
  },
  {
    "type": "assert_visible",
    "selector": "text=Delete Database"
  },
  {
    "type": "click",
    "selector": "text=Delete Database"
  },
  {
    "type": "fill",
    "selector": "input[name=\"sudoCommand\"]",
    "value": "sudo delete database {{db_name}}"
  },
  {
    "type": "assert_visible",
    "selector": "text=Delete Database"
  },
  {
    "type": "click",
    "selector": "text=Delete Database"
  }
]
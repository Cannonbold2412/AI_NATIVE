{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionPlan",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "skill"
    ],
    "properties": {
      "skill": {
        "type": "string",
        "description": "Skill name from plugin index"
      },
      "inputs": {
        "type": "object",
        "description": "Input values for the skill",
        "additionalProperties": {
          "type": "string"
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "conxa/execution-plan/v1",
  "title": "ExecutionPlan",
  "description": "Ordered list of skills to execute. Pass this file to: node execution/executor.js --plan <file>",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": [
      "skill",
      "inputs"
    ],
    "additionalProperties": false,
    "properties": {
      "skill": {
        "type": "string",
        "description": "Skill name from render.json",
        "enum": [
          "generated_skill"
        ]
      },
      "inputs": {
        "type": "object",
        "description": "Runtime input values for this skill",
        "required": [
          "user_email",
          "user_password",
          "db_name"
        ],
        "properties": {
          "user_email": {
            "type": "string",
            "description": "Email address for Render.com login"
          },
          "user_password": {
            "type": "string",
            "description": "Password for Render.com login (sensitive)"
          },
          "db_name": {
            "type": "string",
            "description": "Name of the database to delete"
          }
        }
      }
    }
  }
}

{
  "name": "conxa-runtime",
  "version": "1.0.0",
  "description": "Conxa local AI runtime — MCP server for company workflow skills",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:win": "npx @yao-pkg/pkg . --targets node20-win-x64 --out-path dist/",
    "build:mac": "npx @yao-pkg/pkg . --targets node20-mac-x64 --out-path dist/",
    "build:all": "npx @yao-pkg/pkg . --targets node20-win-x64,node20-mac-x64 --out-path dist/"
  },
  "pkg": {
    "targets": ["node20-win-x64", "node20-mac-x64"],
    "outputPath": "dist/",
    "scripts": [
      "server.js",
      "skill_loader.js",
      "sync.js",
      "auth_manager.js",
      "run.js",
      "browser.js"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright": "^1.45.0",
    "keytar": "^7.9.0",
    "semver": "^7.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}

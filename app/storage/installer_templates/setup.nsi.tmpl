; Conxa Runtime Installer — generated by installer_builder.py
; DO NOT EDIT MANUALLY. Regenerate via the Conxa dashboard.
;
; Placeholders replaced at build time:
;   {{COMPANY_SLUG}}    e.g. acme
;   {{COMPANY_NAME}}    e.g. Acme Corp
;   {{VERSION}}         skill pack version
;   {{RUNTIME_VERSION}} runtime exe version
;   {{STAGING_DIR}}     temp dir containing staged files

!define COMPANY_SLUG   "{{COMPANY_SLUG}}"
!define COMPANY_NAME   "{{COMPANY_NAME}}"
!define VERSION        "{{VERSION}}"
!define RUNTIME_VER    "{{RUNTIME_VERSION}}"
!define STAGING_DIR    "{{STAGING_DIR}}"
!define INSTALL_DIR    "$PROGRAMFILES64\Conxa"
!define RUNTIME_DIR    "${INSTALL_DIR}\runtime"
!define CHROMIUM_DIR   "${INSTALL_DIR}\chromium"
!define SKILL_DIR      "${INSTALL_DIR}\skill-packs\${COMPANY_SLUG}"
!define CLAUDE_CONFIG       "$APPDATA\Claude\claude_desktop_config.json"
!define CLAUDE_CODE_CONFIG  "$PROFILE\.claude.json"
!define UNINSTALL_KEY  "Software\Microsoft\Windows\CurrentVersion\Uninstall\Conxa-${COMPANY_SLUG}"

Name          "${COMPANY_NAME} for Claude"
OutFile       "${OUTPUT_PATH}"
InstallDir    "${INSTALL_DIR}"
RequestExecutionLevel admin
SetCompressor  lzma
Unicode True

; ── Variables ─────────────────────────────────────────────────────────────────
Var RuntimePresent

; ── Detect compatible runtime ─────────────────────────────────────────────────
Function DetectRuntime
  StrCpy $RuntimePresent "0"
  IfFileExists "${RUNTIME_DIR}\version.json" 0 detect_done
  ; Read installed version — simplified: presence of version.json = compatible
  ; Production: use nsJSON or a custom plugin to parse and semver-compare
  StrCpy $RuntimePresent "1"
  detect_done:
FunctionEnd

; ── Runtime section ───────────────────────────────────────────────────────────
Section "Runtime" SEC_RUNTIME
  ; Stop any running runtime so the exe can be replaced
  nsExec::ExecToLog 'taskkill /F /IM runtime.exe'
  SetOutPath "${RUNTIME_DIR}"
  File "${STAGING_DIR}\runtime\runtime.exe"
  File "${STAGING_DIR}\runtime\keytar.node"
  File "${STAGING_DIR}\runtime\version.json"
SectionEnd

; ── Chromium section ──────────────────────────────────────────────────────────
Section "Chromium" SEC_CHROMIUM
  IfFileExists "${CHROMIUM_DIR}\*" chromium_skip
  ; Set PLAYWRIGHT_BROWSERS_PATH so Playwright installs to our managed path
  System::Call 'Kernel32::SetEnvironmentVariable(t "PLAYWRIGHT_BROWSERS_PATH", t "${CHROMIUM_DIR}")'
  ExecWait '"${RUNTIME_DIR}\runtime.exe" "--install-playwright"' $0
  IntCmp $0 0 chromium_skip
  MessageBox MB_OK "Chromium installation failed (code $0). Automation may not work.$\nYou can retry by running:$\n${RUNTIME_DIR}\runtime.exe --install-playwright"
  chromium_skip:
SectionEnd

; ── Skill packs section ───────────────────────────────────────────────────────
Section "SkillPacks" SEC_SKILLS
  SetOutPath "${SKILL_DIR}"
  ; Copy company skill pack — preserves other companies' directories
  File /r "${STAGING_DIR}\skill-packs\${COMPANY_SLUG}\*.*"
SectionEnd

; ── Deep-link registration ─────────────────────────────────────────────────────
Section "DeepLink" SEC_DEEPLINK
  ; Register conxa-runtime:// URI scheme so auth callbacks reach the runtime
  WriteRegStr HKCR "conxa-runtime"                   "" "URL:Conxa Runtime"
  WriteRegStr HKCR "conxa-runtime"                   "URL Protocol" ""
  WriteRegStr HKCR "conxa-runtime\DefaultIcon"       "" "${RUNTIME_DIR}\runtime.exe,0"
  WriteRegStr HKCR "conxa-runtime\shell"             "" "open"
  WriteRegStr HKCR "conxa-runtime\shell\open\command" "" \
    '"${RUNTIME_DIR}\runtime.exe" "--handle-auth-callback" "%1"'
SectionEnd

; ── MCP registration ──────────────────────────────────────────────────────────
Section "MCPRegistration" SEC_MCP
  ; Check Claude Code config first (~/.claude.json)
  IfFileExists "${CLAUDE_CODE_CONFIG}" mcp_found
  ; Try Claude Desktop APPDATA path
  IfFileExists "${CLAUDE_CONFIG}" mcp_found
  ; Try Claude Desktop LOCALAPPDATA path
  IfFileExists "$LOCALAPPDATA\Claude\claude_desktop_config.json" mcp_localappdata
  ; Neither Claude Code nor Claude Desktop found
  MessageBox MB_OK "Claude not found.$\n$\nInstall Claude from https://claude.in/download and then re-run this installer to enable ${COMPANY_NAME} skills.$\n$\nYou can also manually add Conxa to your .claude.json or claude_desktop_config.json."
  Goto mcp_skip
  mcp_localappdata:
  StrCpy $0 "$LOCALAPPDATA\Claude\claude_desktop_config.json"
  Goto mcp_register
  mcp_found:
  StrCpy $0 "${CLAUDE_CODE_CONFIG}"
  IfFileExists "$0" mcp_register
  StrCpy $0 "${CLAUDE_CONFIG}"
  mcp_register:
  ; Backup existing config
  CopyFiles $0 "$0.conxa.bak"
  ; Merge conxa MCP entry using runtime.exe helper
  ExecWait '"${RUNTIME_DIR}\runtime.exe" "--register-mcp" "$0"' $1
  IntCmp $1 0 mcp_skip
  MessageBox MB_OK "Failed to register Conxa MCP (code $1).$\nPlease add the following to your .claude.json manually:$\n{ $\"mcpServers$\": { $\"conxa$\": { $\"command$\": $\"${RUNTIME_DIR}\\runtime.exe$\" } } }"
  mcp_skip:
SectionEnd

; ── Uninstaller ────────────────────────────────────────────────────────────────
Section "Uninstall"
  ; Remove this company's skill packs only
  RMDir /r "${SKILL_DIR}"
  ; Remove deep-link registration (shared — only remove if no other skill packs remain)
  IfFileExists "${INSTALL_DIR}\skill-packs\*.*" skip_deeplink_removal
  DeleteRegKey HKCR "conxa-runtime"
  skip_deeplink_removal:
  ; Remove MCP registration only if no other companies remain
  IfFileExists "${INSTALL_DIR}\skill-packs\*.*" skip_mcp_removal
  IfFileExists "${CLAUDE_CODE_CONFIG}" do_unregister_code
  IfFileExists "${CLAUDE_CONFIG}" do_unregister_mcp
  IfFileExists "$LOCALAPPDATA\Claude\claude_desktop_config.json" do_unregister_localappdata
  Goto skip_mcp_removal
  do_unregister_code:
  ExecWait '"${RUNTIME_DIR}\runtime.exe" "--unregister-mcp" "${CLAUDE_CODE_CONFIG}"'
  Goto skip_mcp_removal
  do_unregister_localappdata:
  ExecWait '"${RUNTIME_DIR}\runtime.exe" "--unregister-mcp" "$LOCALAPPDATA\Claude\claude_desktop_config.json"'
  Goto skip_mcp_removal
  do_unregister_mcp:
  ExecWait '"${RUNTIME_DIR}\runtime.exe" "--unregister-mcp" "${CLAUDE_CONFIG}"'
  skip_mcp_removal:
  ; Remove runtime only if no skill packs remain
  IfFileExists "${INSTALL_DIR}\skill-packs\*.*" skip_runtime_removal
  RMDir /r "${RUNTIME_DIR}"
  RMDir /r "${CHROMIUM_DIR}"
  RMDir /r "${INSTALL_DIR}\cache"
  RMDir /r "${INSTALL_DIR}\logs"
  RMDir "${INSTALL_DIR}"
  skip_runtime_removal:
  DeleteRegKey HKLM "${UNINSTALL_KEY}"
SectionEnd

; ── Uninstaller registry entry ─────────────────────────────────────────────────
Section -Post
  WriteRegStr HKLM "${UNINSTALL_KEY}" "DisplayName"     "${COMPANY_NAME} for Claude"
  WriteRegStr HKLM "${UNINSTALL_KEY}" "UninstallString" "${INSTALL_DIR}\uninstall-${COMPANY_SLUG}.exe"
  WriteRegStr HKLM "${UNINSTALL_KEY}" "DisplayVersion"  "${VERSION}"
  WriteRegStr HKLM "${UNINSTALL_KEY}" "Publisher"       "Conxa"
  WriteRegStr HKLM "${UNINSTALL_KEY}" "URLInfoAbout"    "https://conxa.in"
  WriteUninstaller "${INSTALL_DIR}\uninstall-${COMPANY_SLUG}.exe"
SectionEnd
